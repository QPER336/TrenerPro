@model TrenerPro.Models.Client

@{
    ViewData["Title"] = "Nowy Klient";
}

<h1 style="text-align: center; margin-bottom: 30px;">Dodaj Podopiecznego</h1>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="glass-card">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="FirstName" class="control-label"></label>
                        <input asp-for="FirstName" class="form-control" placeholder="Imię" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="LastName" class="control-label"></label>
                        <input asp-for="LastName" class="form-control" placeholder="Nazwisko" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Age" class="control-label"></label>
                        <input asp-for="Age" class="form-control" />
                        <span asp-validation-for="Age" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="JoinDate" class="control-label"></label>
                        <input asp-for="JoinDate" class="form-control" />
                        <span asp-validation-for="JoinDate" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="PlanEndDate" class="control-label"></label>
                        <input asp-for="PlanEndDate" class="form-control" />
                        <span asp-validation-for="PlanEndDate" class="text-danger"></span>
                    </div>
                </div>

                <hr style="border-color: rgba(255,255,255,0.1); margin: 20px 0;">

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="StartWeight" class="control-label"></label>
                        <input asp-for="StartWeight" class="form-control" />
                        <span asp-validation-for="StartWeight" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="CurrentWeight" class="control-label"></label>
                        <input asp-for="CurrentWeight" class="form-control" />
                        <span asp-validation-for="CurrentWeight" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="ServiceType" class="control-label"></label>
                    <select asp-for="ServiceType"
                            class="form-control"
                            asp-items="Html.GetEnumSelectList<TrenerPro.Models.ServiceType>()">
                        <option value="">-- Wybierz rodzaj usługi --</option>
                    </select>
                    <span asp-validation-for="ServiceType" class="text-danger"></span>
                </div>

                <div class="form-group d-grid gap-2">
                    <input type="submit" value="Utwórz Klienta" class="btn-modern" style="justify-content: center;" />
                    <a asp-action="Index" class="btn-outline">Powrót do listy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}