@page
@model LoginModel

@{
    ViewData["Title"] = "Logowanie";
}

<div class="row justify-content-center" style="margin-top: 50px;">
    <div class="col-md-5">
        <div class="glass-card" style="padding: 3rem; text-align: center;">

            <img src="~/images/logo.jpg" style="width: 100px; border-radius: 15px; box-shadow: 0 0 30px rgba(139, 92, 246, 0.3); margin-bottom: 2rem;" />

            <h1 style="font-size: 2rem; margin-bottom: 0.5rem; color: white;">Witaj Trenerze</h1>
            <p style="color: var(--text-muted); margin-bottom: 2rem;">Zaloguj się, aby zarządzać imperium.</p>

            <section>
                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" style="text-align: center;" />
                        <label asp-for="Input.Email" style="color: var(--text-muted); width: 100%;">Adres Email</label>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" style="text-align: center;" />
                        <label asp-for="Input.Password" style="color: var(--text-muted); width: 100%;">Hasło</label>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="mb-4" style="text-align: left; padding-left: 5px;">
                        <label asp-for="Input.RememberMe" class="form-label" style="color: var(--text-muted); cursor: pointer;">
                            <input class="form-check-input" asp-for="Input.RememberMe" style="background-color: #000; border-color: #555; margin-right: 8px;" />
                            @Html.DisplayNameFor(m => m.Input.RememberMe)
                        </label>
                    </div>

                    <div class="d-grid gap-2">
                        <button id="login-submit" type="submit" class="btn-modern" style="padding: 12px; font-size: 1.1rem; justify-content: center;">
                            <i class="fa-solid fa-right-to-bracket"></i> Zaloguj się
                        </button>
                    </div>

                    <div style="margin-top: 1.5rem; display: flex; flex-direction: column; gap: 10px; font-size: 0.9rem;">
                        <a id="forgot-password" asp-page="./ForgotPassword" style="color: var(--text-muted); text-decoration: none;">Zapomniałeś hasła?</a>
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" style="color: var(--accent); font-weight: 600;">Nie masz konta? Zarejestruj się</a>
                    </div>
                </form>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}