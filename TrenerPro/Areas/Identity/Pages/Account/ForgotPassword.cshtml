@page
@model TrenerPro.Areas.Identity.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Zapomniałeś hasła?";
}

<div class="row justify-content-center" style="margin-top: 50px;">
    <div class="col-md-5">
        <div class="glass-card" style="padding: 3rem; text-align: center;">

            <i class="fa-solid fa-lock-open" style="font-size: 3rem; color: var(--primary); margin-bottom: 1rem; opacity: 0.8; text-shadow: 0 0 20px var(--primary);"></i>

            <h1 style="font-size: 2rem; margin-bottom: 0.5rem; color: white;">Odzyskaj dostęp</h1>
            <p style="color: var(--text-muted); margin-bottom: 2rem;">Podaj swój email, a wyślemy Ci link do ustawienia nowego hasła.</p>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-floating mb-4">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" style="text-align: center;" />
                    <label asp-for="Input.Email" style="color: var(--text-muted); width: 100%;">Twój adres Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn-modern" style="padding: 12px; font-size: 1.1rem; justify-content: center;">
                        <i class="fa-solid fa-paper-plane"></i> Wyślij link
                    </button>
                </div>

                <div style="margin-top: 1.5rem; font-size: 0.9rem;">
                    <a asp-page="./Login" style="color: var(--text-muted); text-decoration: none; transition: 0.3s;">
                        <i class="fa-solid fa-arrow-left"></i> Wróć do logowania
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}