@page
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@{
    ViewData["Title"] = "Sprawdź skrzynkę";
}

<div class="row justify-content-center" style="margin-top: 50px;">
    <div class="col-md-5">
        <div class="glass-card" style="padding: 3rem; text-align: center;">

            <i class="fa-solid fa-envelope-circle-check" style="font-size: 4rem; color: var(--accent); margin-bottom: 1.5rem; text-shadow: 0 0 20px var(--accent);"></i>

            <h1 style="font-size: 2rem; margin-bottom: 1rem; color: white;">Sprawdź skrzynkę!</h1>

            <p style="color: var(--text-muted); margin-bottom: 2rem; line-height: 1.6;">
                Wysłaliśmy wiadomość na podany adres email. Kliknij w link wewnątrz wiadomości, aby bezpiecznie zresetować swoje hasło.
            </p>

            <a asp-page="./Login" class="btn-outline" style="padding: 10px 30px;">
                Wróć do logowania
            </a>
        </div>
    </div>
</div>