@page
@model TrenerPro.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Rejestracja";
}

<div class="row justify-content-center" style="margin-top: 50px;">
    <div class="col-md-5">
        <div class="glass-card" style="padding: 3rem; text-align: center;">

            <h1 style="font-size: 2rem; margin-bottom: 0.5rem; color: white;">Dołącz do BeFit</h1>
            <p style="color: var(--text-muted); margin-bottom: 2rem;">Zacznij budować swoją markę osobistą.</p>

            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" style="text-align: center;" />
                    <label asp-for="Input.Email" style="color: var(--text-muted); width: 100%;">Adres Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" style="text-align: center;" />
                    <label asp-for="Input.Password" style="color: var(--text-muted); width: 100%;">Hasło</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="form-floating mb-4">
                    <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" style="text-align: center;" />
                    <label asp-for="Input.ConfirmPassword" style="color: var(--text-muted); width: 100%;">Potwierdź hasło</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>

                <div class="d-grid gap-2">
                    <button id="registerSubmit" type="submit" class="btn-modern" style="padding: 12px; font-size: 1.1rem; justify-content: center;">
                        <i class="fa-solid fa-user-plus"></i> Załóż konto
                    </button>
                </div>

                <div style="margin-top: 1.5rem; font-size: 0.9rem;">
                    <a asp-page="./Login" style="color: var(--text-muted);">Masz już konto? <span style="color: var(--primary); font-weight: 600;">Zaloguj się</span></a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}