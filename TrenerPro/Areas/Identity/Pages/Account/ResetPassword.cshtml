@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Ustaw nowe hasło";
}

<div class="row justify-content-center" style="margin-top: 50px;">
    <div class="col-md-5">
        <div class="glass-card" style="padding: 3rem; text-align: center;">

            <i class="fa-solid fa-key" style="font-size: 3rem; color: var(--primary); margin-bottom: 1rem; opacity: 0.8; text-shadow: 0 0 20px var(--primary);"></i>

            <h1 style="font-size: 2rem; margin-bottom: 0.5rem; color: white;">Nowy start</h1>
            <p style="color: var(--text-muted); margin-bottom: 2rem;">Wprowadź nowe hasło dla swojego konta.</p>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <input asp-for="Input.Code" type="hidden" />
                <input asp-for="Input.Email" type="hidden" />

                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Nowe hasło" style="text-align: center;" />
                    <label asp-for="Input.Password" style="color: var(--text-muted); width: 100%;">Nowe hasło</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="form-floating mb-4">
                    <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Potwierdź hasło" style="text-align: center;" />
                    <label asp-for="Input.ConfirmPassword" style="color: var(--text-muted); width: 100%;">Potwierdź hasło</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn-modern" style="padding: 12px; font-size: 1.1rem; justify-content: center;">
                        <i class="fa-solid fa-check"></i> Zmień hasło
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}